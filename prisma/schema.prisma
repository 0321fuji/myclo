generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ClothingItem {
  id                String    @id @default(cuid())
  userId            String
  name              String
  brand             String?
  productName       String?
  category          String
  silhouette        String?
  colors            String
  materials         String   @default("[]")
  tags              String
  style             String
  imageUrl          String?
  imageBgRemovedUrl String?
  wornCount         Int       @default(0)
  lastWornAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  outfitItems OutfitItem[]
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  gender          String?  // "male" | "female" | "other"
  ageGroup        String?  // "10s" | "20s_early" | "20s_late" | "30s" | "40s" | "50s+"
  height          Int?     // cm
  bodyType        String?  // "straight" | "wave" | "natural" | "unknown"
  personalColor   String?  // "spring" | "summer" | "autumn" | "winter" | "unknown"
  preferredStyles String   @default("[]")  // JSON array
  dislikedStyles  String   @default("[]")  // JSON array
  inspirations    String?  // 憧れのブランド・人 自由記述
  occupation      String?  // "office" | "creative" | "student" | "freelance" | "other"
  scenes          String   @default("[]")  // ["office","date","casual","formal","sport"]
  avoid           String?  // 避けたいこと 自由記述
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Outfit {
  id          String    @id @default(cuid())
  style       String
  description String?
  isFavorite  Boolean   @default(false)
  wornDate    DateTime?
  temperature Float?
  weather     String?
  createdAt   DateTime  @default(now())

  items OutfitItem[]
}

model OutfitItem {
  id             String       @id @default(cuid())
  outfitId       String
  clothingItemId String
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  clothingItem   ClothingItem @relation(fields: [clothingItemId], references: [id], onDelete: Cascade)
}
